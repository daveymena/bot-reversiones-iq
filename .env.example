# ════════════════════════════════════════════════════
# EXNOVA TRADING BOT — Variables de Entorno
# Copia este archivo como .env y rellena tus valores
# NUNCA subas el archivo .env al repositorio
# ════════════════════════════════════════════════════

# ── Credenciales Exnova / IQ Option ──────────────────
EXNOVA_EMAIL=tu@email.com
EXNOVA_PASSWORD=tu_password

# ── OpenCode AI (EasyPanel) ───────────────────────────
# Motor de razonamiento y mejora continua del bot
OPENCODE_BASE_URL=https://tecnovariedades-provedor-ia.er7iaf.easypanel.host/v1
OPENCODE_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENCODE_MODEL_FAST=opencode/deepseek-v4-flash-free
OPENCODE_MODEL_DEEP=opencode/qwen3.6-plus-free

# ── GitHub Token (GitHub Models — fallback) ──────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Configuración del Bot ─────────────────────────────
# Balance inicial de práctica (si no se puede leer de la API)
INITIAL_BALANCE=10000

# Mínimo de confianza para operar (0.0 - 1.0)
MIN_CONFIDENCE=0.70

# Máximo de pérdidas consecutivas antes de pausar
MAX_CONSEC_LOSSES=3

# Cooldown entre trades en segundos
MIN_BETWEEN_TRADES=30
COOLDOWN_AFTER_LOSS=90

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
